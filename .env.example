# Supabase — required for Realtime presence and signaling
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: demo playback URL for local testing without mobile clients
# VITE_DEMO_PLAYBACK_URL=https://your-regal-stream-endpoint

# RTMP broadcast relay (required for GO LIVE → RTMP push from the browser)
# Run: npm run broadcast-relay
VITE_BROADCAST_RELAY_WS=ws://localhost:8090
# Optional shared secret (must match RELAY_TOKEN on the relay server)
# VITE_BROADCAST_RELAY_TOKEN=your-relay-secret

# API.Bible — NKJV, NIV, ESV, NASB, NLT, The Message, Passion Translation, etc.
# https://scripture.api.bible/signup
# VITE_API_BIBLE_KEY=your-api-bible-key

# Supabase heartbeat (free-tier keep-alive) — also used by `npm run heartbeat`
# GitHub Actions (.github/workflows/supabase-heartbeat.yml) needs:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# Transactional email (Resend + Supabase Edge Function)
# RESEND_API_KEY=re_...                    # https://resend.com/api-keys — required for live delivery
# FROM_EMAIL=CloudCast by Quantum Regal <notifications@cloudcast.regal>
# EMAIL_WEBHOOK_SECRET=auto-synced from DB via npm run secrets:email
# EMAIL_TEST_TO=you@example.com            # optional recipient for npm run setup:email test send
# APP_PUBLIC_URL=https://cloudcast.pleromadoxa.workers.dev
# VITE_APP_URL=https://cloudcast.live              # canonical site URL for SEO, sitemap, and OG tags
# Setup: npm run setup:email
# Sync secrets only: npm run secrets:email
# Preview templates: npm run email:preview

# Stripe billing (production checkout on /pricing)
# STRIPE_SECRET_KEY=sk_live_...              # https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET=whsec_...             # Stripe webhook → .../functions/v1/stripe-webhook
# VITE_STRIPE_ENABLED=true                    # set by npm run setup:stripe
# Setup: npm run setup:stripe && npm run deploy:stripe

# Cloudflare — frontend deploy (npm run deploy:pages) + R2 / Stream edge functions
# CLOUDFLARE_API_TOKEN=   # needs Account → Stream → Edit (not just Workers/R2)
# CLOUDFLARE_ACCOUNT_ID=
# Verify Stream access: npm run verify:stream
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=cloudcast-recordings
# Setup: npm run setup:r2 && npm run deploy:r2
