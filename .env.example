# Supabase — required for Realtime presence and signaling
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: demo playback URL for local testing without mobile clients
# VITE_DEMO_PLAYBACK_URL=https://your-regal-stream-endpoint

# RTMP broadcast relay (required for GO LIVE → RTMP push from the browser)
# Run: npm run broadcast-relay
VITE_BROADCAST_RELAY_WS=ws://localhost:8090
# Optional shared secret (must match RELAY_TOKEN on the relay server)
# VITE_BROADCAST_RELAY_TOKEN=your-relay-secret

# Supabase heartbeat (free-tier keep-alive) — also used by `npm run heartbeat`
# For GitHub Actions, add SUPABASE_URL + SUPABASE_ANON_KEY as repo secrets.
# Optional: SUPABASE_SERVICE_ROLE_KEY processes the transactional email queue on each heartbeat.

# Transactional email (Supabase Edge Function secrets — set via `supabase secrets set`)
# RESEND_API_KEY=re_...
# FROM_EMAIL=CloudCast <notifications@yourdomain.com>
# APP_PUBLIC_URL=https://your-production-domain.com
# EMAIL_WEBHOOK_SECRET=must-match-app_internal_settings.email_webhook_secret-in-db
