{
  "name": "cloudcast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "broadcast-relay": "node tools/broadcast-relay/server.mjs",
    "heartbeat": "node tools/supabase-heartbeat.mjs",
    "heartbeat:loop": "node tools/supabase-heartbeat.mjs --loop",
    "setup:r2": "node tools/setup-cloudcast-r2.mjs",
    "secrets:r2": "node tools/sync-r2-secrets.mjs",
    "deploy:r2": "npm run secrets:r2 && supabase functions deploy cloudcast-r2",
    "deploy:stream": "supabase functions deploy cloudcast-stream",
    "deploy:cloudflare": "npm run deploy:r2 && supabase functions deploy cloudcast-stream"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "ws": "^8.18.0"
  }
}
